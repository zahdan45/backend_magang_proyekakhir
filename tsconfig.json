{
  "compilerOptions": {
    /* Type Checking */
    "strict": true, 
    "noUnusedLocals": false,      /* UBAH JADI FALSE (Agar build tidak gagal karena variabel tak terpakai) */
    "noUnusedParameters": false,  /* Tetap false */
    "noImplicitReturns": true, 
    "noImplicitAny": false,       /* Tetap false agar 'any' diperbolehkan */

    /* Modules */
    "module": "NodeNext", 
    "moduleResolution": "NodeNext", 
    "resolveJsonModule": true, 

    /* Emit */
    "outDir": "./dist", 
    "rootDir": "./src",           /* TAMBAHKAN INI agar struktur folder dist rapi */
    "sourceMap": true, 

    /* Interop */
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true, 

    /* Language and Environment */
    "target": "ES2022", 
    "lib": ["ES2022"],
    "skipLibCheck": true 
  },
  "include": ["src/**/*"], 
  "exclude": ["node_modules"] 
}