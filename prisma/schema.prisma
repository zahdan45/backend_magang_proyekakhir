// GUNAKAN ISI FILE INI UNTUK KEDUA FOLDER (FRONTEND & BACKEND)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USER (Khusus Google Auth) ---
model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  image            String?  // Foto profil dari Google
  role             String   @default("USER")
  canEditThreshold Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// --- AREA (Pengganti Warehouse) ---
model Area {
  id        String   @id @default(uuid())
  name      String   // Contoh: "Ruang Server", "Gudang 1"
  devices   Device[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- DEVICE ---
model Device {
  id         String      @id @default(uuid())
  name       String
  type       String      // Microcontroller / Sensor
  status     String      @default("offline")
  
  // Relasi ke Area
  areaId     String
  area       Area        @relation(fields: [areaId], references: [id], onDelete: Cascade)

  // Relasi Data
  incidents  Incident[]
  sensorLogs SensorLog[] // Untuk grafik suhu & air
  
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

// --- SENSOR LOG (PENTING UNTUK GRAFIK & HISTORIS) ---
// Backend (MQTT) akan mengisi tabel ini setiap menit atau saat ada anomali
model SensorLog {
  id          String   @id @default(uuid())
  
  temperature Float?   // Menyimpan suhu rata-rata (misal: 36.5)
  tempMin     Float?   // Menyimpan suhu terendah
  tempMax     Float?   // Menyimpan suhu tertinggi
  aiLoss      Float?   // Menyimpan nilai MSE dari Autoencoder
  weather     String?  // Menyimpan deskripsi cuaca saat itu
  waterLevel  Int?     // Menyimpan raw data air (misal: 450)
  
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now()) // Waktu data masuk
  
  @@index([deviceId, createdAt]) // Agar loading grafik cepat
}

// --- INCIDENT ---
model Incident {
  id          String   @id @default(uuid())
  type        String
  description String?
  
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id])
  
  timestamp   DateTime @default(now())
  isResolved  Boolean  @default(false)
}